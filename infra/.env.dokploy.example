# Copy to infra/.env.dokploy and fill in. Used by infra/dokploy-deploy.sh.
# (The GitHub Action uses repo Secrets with the same names, set in
#  Settings → Secrets and variables → Actions.)

# Dokploy dashboard base URL, e.g. https://dokploy.example.com
DOKPLOY_URL=

# Generated in Dokploy → profile → API/CLI
DOKPLOY_API_KEY=

# Application IDs from Dokploy (run: ./infra/dokploy-deploy.sh ids)
DOKPLOY_API_APP_ID=
DOKPLOY_DASHBOARD_APP_ID=
