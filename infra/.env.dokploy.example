# Copy to infra/.env.dokploy and fill in. Used by infra/dokploy-deploy.sh.
# (The GitHub Action uses repo Secrets with the same names, set in
#  Settings → Secrets and variables → Actions.)

# Dokploy dashboard base URL, e.g. https://dokploy.example.com
DOKPLOY_URL=

# Generated in Dokploy → profile → API/CLI
DOKPLOY_API_KEY=

# Application IDs from Dokploy. Created/printed by ./infra/dokploy-provision.sh
# (or discover existing ones with ./infra/dokploy-deploy.sh ids).
DOKPLOY_API_APP_ID=
DOKPLOY_DASHBOARD_APP_ID=

# ---- Only needed by ./infra/dokploy-provision.sh (creating the apps) ----
# GHCR namespace/owner for the images (ghcr.io/<owner>/laundry-api etc.)
GHCR_OWNER=yassineelouafi
# GitHub username + a PAT with read:packages, so Dokploy can pull from GHCR.
GHCR_USERNAME=
GHCR_PAT=
# Optional public domains (skip to configure later in the UI). With Cloudflare,
# set DNS-only (grey cloud) so Let's Encrypt HTTP-01 works.
DOMAIN_API=
DOMAIN_DASHBOARD=
