# Copy to `.env` and fill in. Expo auto-loads .env and inlines EXPO_PUBLIC_* at
# build time. `.env` is gitignored — never commit real values. See
# docs/social-login-setup.md for where each value comes from.

# API base URL (optional — defaults to the deployed API in src/lib/env.ts)
# EXPO_PUBLIC_API_URL=https://your-api.example.com/api/v1

# --- Google Sign-In ---
# WEB client id: the audience the API verifies the idToken against.
# MUST be identical to the API's GOOGLE_CLIENT_ID.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS client id (from the iOS OAuth client). Optional but recommended.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# --- Apple / Facebook ---
# These are NOT JS env vars — they are configured natively in app.json:
#   Apple:    ios.usesAppleSignIn + expo-apple-authentication plugin (already set)
#   Facebook: react-native-fbsdk-next plugin (appID / clientToken / scheme)
# Replace the REPLACE_WITH_* placeholders in app.json instead.
